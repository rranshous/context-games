{
  "name": "surrender-or-die",
  "version": "0.2.0",
  "description": "Castle wars micro-RTS — surrender or die",
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "start": "node dist/server.js",
    "bot": "node dist/bot.js",
    "bot:easy": "SOD_DIFFICULTY=easy node dist/bot.js",
    "bot:hard": "SOD_DIFFICULTY=hard node dist/bot.js",
    "dev": "node esbuild.config.mjs && node dist/server.js"
  },
  "keywords": ["game", "rts"],
  "author": "Robby Ranshous",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.9.3"
  }
}
