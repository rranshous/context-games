{
  "name": "bloom-chassis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch chassis/main.ts",
    "tick": "ONCE=1 tsx chassis/main.ts",
    "start": "tsx chassis/main.ts",
    "reset": "cp soma-defaults/* soma/ && rm -rf games/ && rm -f ../frame/data/*.json && echo 'bloom reset to defaults'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^17.3.1",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
